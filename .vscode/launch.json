{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Launch",
            "program": "${workspaceFolder}/<program>",
            "args": [                    "http://browser.engineering"],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'ZipSurf'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=ZipSurf",
                    "--package=ZipSurf"
                ],
                "filter": {
                    "name": "ZipSurf",
                    "kind": "bin"
                }
            },
            "args": ["http://browser.engineering"],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'ZipSurf'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=ZipSurf",
                    "--package=ZipSurf"
                ],
                "filter": {
                    "name": "ZipSurf",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}